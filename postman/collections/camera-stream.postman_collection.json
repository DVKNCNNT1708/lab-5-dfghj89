{
  "info": {
    "_postman_id": "camera-stream-a2-collection",
    "name": "Camera Stream API - Team A2",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Health Check",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/health",
          "host": ["{{baseUrl}}"],
          "path": ["health"]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status is 200', () => pm.response.to.have.status(200));",
              "pm.test('Service is camera-stream', () => pm.expect(pm.response.json().service).to.contain('camera-stream'));"
            ]
          }
        }
      ]
    },
    {
      "name": "Trigger Detection (Async)",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Authorization", "value": "Bearer {{authToken}}" },
          { "key": "Content-Type", "value": "application/json" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"cameraId\": \"{{cameraId}}\",\n  \"frameUrl\": \"https://campus.local/frame01.jpg\",\n  \"timestamp\": \"{{$isoTimestamp}}\",\n  \"requestId\": \"REQ-{{$randomInt}}\",\n  \"analysisType\": \"PERSON_DETECTION\"\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/detect",
          "host": ["{{baseUrl}}"],
          "path": ["detect"]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Returns 202 Accepted', () => pm.response.to.have.status(202));",
              "const json = pm.response.json();",
              "pm.test('Has detectionId', () => pm.expect(json.detectionId).to.exist);",
              "pm.globals.set('lastDetectionId', json.detectionId);"
            ]
          }
        }
      ]
    },
    {
      "name": "Get Detection Detail",
      "request": {
        "method": "GET",
        "header": [
          { "key": "Authorization", "value": "Bearer {{authToken}}" }
        ],
        "url": {
          "raw": "{{baseUrl}}/detections/{{lastDetectionId}}",
          "host": ["{{baseUrl}}"],
          "path": ["detections", "{{lastDetectionId}}"]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status is 200', () => pm.response.to.have.status(200));",
              "const json = pm.response.json();",
              "pm.test('Has valid status', () => pm.expect(json.status).to.be.oneOf(['PROCESSING', 'COMPLETED', 'ACCEPTED']));"
            ]
          }
        }
      ]
    }
  ]
}
